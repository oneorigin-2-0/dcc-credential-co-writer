# Copy to .env and adjust per deployment.

# --- Public origins -----------------------------------------------------
# Origin the browser loads the frontend from. Used as the CORS allowlist on
# both APIs. Comma-separated for multiple origins.
CORS_ORIGINS_STR=http://localhost:3000

# Base URL the browser uses to reach the SLM API (baked into the frontend
# build). Must be reachable from the user's browser, not just the host.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Public base URL used inside Open Badge v3 metadata (achievement image id).
BADGE_ISSUER_URL=http://localhost:8000

# --- Model weights --------------------------------------------------------
# Path on the host to the trained phi-4-mini GGUF. Default points at the
# OneNAS read-only mount; external deployments point this at their own copy.
MODEL_GGUF_PATH=/mnt/onenas-models/phi4-gguf/Phi-4-mini-instruct_Q4_K_M.gguf

# --- Host port mappings --------------------------------------------------
FRONTEND_PORT=3000
SLM_PORT=8000
IMAGE_GEN_PORT=3001
