# ============================================
# SLM Badge Generator Configuration
# ============================================

# Ollama Configuration
OLLAMA_API_URL=http://localhost:11434/api/generate
MODEL_NAME=phi4-chat:latest

# Badge Image Service Configuration
BADGE_IMAGE_SERVICE_URL=http://localhost:3001

# ============================================
# CORS Configuration
# ============================================
# Comma-separated allowlist of origins permitted to call the API.
# Explicit origins are required because credentialed CORS requests are
# incompatible with a wildcard ("*") origin.
CORS_ORIGINS_STR=http://localhost:3000

# ============================================
# Open Badge v3 Issuer Configuration
# ============================================
# Base URL used to build the achievement image `id` (an IRI) in badge responses.
BADGE_ISSUER_URL=http://localhost:8000

# ============================================
# LAiSER Skill Extraction Configuration
# ============================================


# HuggingFace model for skill extraction (NOT GGUF format)
# Recommended: bert-base-uncased, distilbert-base-uncased, roberta-base
LAISER_MODEL_ID=bert-base-uncased

# HuggingFace API Token (get yours at https://huggingface.co/settings/tokens)
LAISER_HF_TOKEN=

# GPU Acceleration (set to true after GPU setup - see GPU_INSTALL.txt)
LAISER_USE_GPU=false

# Number of skills to extract per badge (5-20 recommended)
LAISER_TOP_K=10
