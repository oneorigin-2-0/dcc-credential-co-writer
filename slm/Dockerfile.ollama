#Build - Create the model
FROM alpine/ollama:latest AS builder

# Copy model files
COPY models/ /models/

# Set working directory
WORKDIR /models

# Start Ollama in background, create model, then stop
RUN ollama serve & \
    OLLAMA_PID=$! && \
    sleep 5 && \
    ollama create phi4-chat -f Modelfile && \
    kill $OLLAMA_PID && \
    wait $OLLAMA_PID || true

#Only copy the created model (removes source GGUF duplication)
FROM alpine/ollama:latest

# Copy only Ollama's model storage from builder stage (NOT the source GGUF file)
COPY --from=builder /root/.ollama /root/.ollama

# Expose Ollama port
EXPOSE 11434

# Start Ollama server
CMD ["serve"]

