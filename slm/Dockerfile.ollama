#Build - Create the model
FROM alpine/ollama:latest AS builder

# Copy model files
COPY models/ /models/

# Set working directory
WORKDIR /models

# Start Ollama in background, create model, then stop
RUN ollama serve & \
    OLLAMA_PID=$! && \
    sleep 5 && \
    ollama create phi4-chat -f Modelfile && \
    kill $OLLAMA_PID && \
    wait $OLLAMA_PID || true

# Copy baked model storage + keep source files for fallback creation if needed
FROM alpine/ollama:latest

COPY --from=builder /root/.ollama /root/.ollama
# COPY models/ /models/

EXPOSE 11434
CMD ["serve"]

