# Badge Generator API Configuration

# Project Settings
PROJECT_NAME="Badge Image Generator API"
VERSION="1.0.0"

# Server Settings
PORT=3001

# CORS Settings (comma-separated list of allowed origins).
# Default (when unset) is http://localhost:3000. Do NOT use "*" together with
# credentialed requests: credentials are automatically disabled when origins is
# "*", so set an explicit allowlist for any deployment that needs cookies/auth.
CORS_ORIGINS_STR=http://localhost:3000,http://localhost:8080,http://localhost:8001
